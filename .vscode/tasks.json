{
    "version": "2.0.0",
    "options": {
        "shell": {
            "executable": "wsl.exe",
            "args": ["--", "bash", "-l", "-c"]
        },
        "env": {
            "DISPLAY": ":0",
            "LIBGL_ALWAYS_INDIRECT": "1"
        }
    },
    "tasks": [
        {
            "label": "Run (Linux)",
            "type": "shell",
            "command": "make run",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build Linux",
            "type": "shell",
            "command": "make linux",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build Windows",
            "type": "shell",
            "command": "make windows",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "make debug",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "make clean",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}